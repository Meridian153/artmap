# ArtMap 환경 변수 예시 파일
# 사용법: 이 파일을 .env.local로 복사한 뒤 값을 채워 사용
# cp .env.example .env.local

# Mock 데이터 사용 여부
# - true: 프론트엔드가 src/mocks/ 의 더미 데이터를 사용 (백엔드 API 불필요)
# - false: 실제 백엔드 API 호출 (DATABASE_URL 필요)
# MVP 단계에서는 항상 true 로 설정
NEXT_PUBLIC_USE_MOCK=true

# DB 연결 문자열 (NEXT_PUBLIC_USE_MOCK=false 일 때만 필요)
# Mock 모드에서는 비워두어도 무관
# 프로덕션 값은 백엔드 담당자에게 문의 (팀 위키 또는 Vercel 프로젝트 설정 페이지 참조)
# DATABASE_URL=
